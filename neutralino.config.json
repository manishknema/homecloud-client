{
  "applicationId": "vigyan.onboard",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": { "enabled": true, "writeToLogFile": false },
  "nativeBlockList": [],
  "globalVariables": {},
  "extensions": [
    {
      "id": "vigyan.ext",
      "command": "${NL_PATH}/vigyan-ext${NL_OS == 'Windows' ? '.exe' : ''}",
      "commandLinux": "${NL_PATH}/vigyan-ext",
      "commandDarwin": "${NL_PATH}/vigyan-ext",
      "commandWindows": "${NL_PATH}/vigyan-ext.exe",
      "connectDelay": 200
    }
  ],
  "modes": {
    "window": {
      "title": "VVC Onboard",
      "width": 900,
      "height": 680,
      "minWidth": 800,
      "minHeight": 600,
      "resizable": true,
      "maximize": false,
      "icon": "/resources/icon.png"
    }
  },
  "cli": {
    "binaryName": "vigyan-onboard",
    "resourcesPath": "./resources/",
    "extensionsPath": "./",
    "clientLibrary": "/resources/neutralino.js",
    "binaryVersion": "5.3.0",
    "clientVersion": "3.12.0"
  }
}
